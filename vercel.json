{
  "version": 2,
  "buildCommand": "ng build --configuration production",
  "outputDirectory": "dist/my-angular-app/browser",
  "installCommand": "npm install",
  "framework": "angular",
  "routes": [
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot)$)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
